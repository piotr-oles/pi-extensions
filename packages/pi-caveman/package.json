{
  "name": "@oles/pi-caveman",
  "version": "0.1.0",
  "description": "Pi Agent extension: respond in caveman mode — cut ~75% output tokens while keeping full technical accuracy",
  "repository": {
    "type": "git",
    "url": "https://github.com/piotr-oles/pi-extensions.git",
    "directory": "packages/pi-caveman"
  },
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "files": [
    "src",
    "!src/tests",
    "instructions"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "biome ci src/",
    "fix": "biome check --write src/"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@marcfargas/pi-test-harness": "^0.6.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
