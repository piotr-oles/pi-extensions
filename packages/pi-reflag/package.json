{
  "name": "@piotr-oles/pi-reflag",
  "version": "0.3.0",
  "description": "Pi Agent extension: transparently rewrite grep commands to rg (ripgrep) for faster searches",
  "repository": {
    "type": "git",
    "url": "https://github.com/piotr-oles/pi-extensions.git",
    "directory": "packages/pi-reflag"
  },
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "files": [
    "src",
    "!src/*.test.ts",
    "vendor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "biome ci src/",
    "fix": "biome check --write src/"
  },
  "dependencies": {
    "web-tree-sitter": "^0.26.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
