{
  "name": "pi-review",
  "version": "0.1.0",
  "description": "Pi Agent extension: review markdown files in-browser with inline comments sent back to the agent",
  "repository": {
    "type": "git",
    "url": "https://github.com/piotr-oles/pi-extensions.git",
    "directory": "packages/pi-review"
  },
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "files": [
    "src",
    "!src/server.test.ts",
    "app-dist",
    "media"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build:app": "vite build --config vite.config.ts",
    "test": "vitest run && vitest run --config vitest.app.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.app.json",
    "check": "biome ci src/ app/src/",
    "fix": "biome check --write src/ app/src/"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "open": "^10.1.0",
    "pino": "^10.3.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.1",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.0",
    "vitest": "^3.2.1"
  }
}
